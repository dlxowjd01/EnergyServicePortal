<!DOCTYPE configuration>
<!-- default directory 설정 -->
<decorators defaultdir="/decorators">
	<decorator name="web_layout" page="layout.jsp">
		<pattern>/</pattern>
	</decorator>
	<!-- decorators를 적용시키지 않을 url 패턴 -->
	 <excludes>
