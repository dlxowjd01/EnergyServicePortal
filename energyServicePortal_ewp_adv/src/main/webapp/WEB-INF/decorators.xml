	 	<pattern>/loginUser.do</pattern>
	 	<pattern>/login.loginUser?**</pattern>
	 	<!-- <pattern>/en/prmtevents/prmtEvent.kto?eventId=russiaTransitTour</pattern> -->
	 </excludes>
</decorators>