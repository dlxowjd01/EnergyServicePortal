<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ewp.api.dao.DeviceIoeDao">
    <resultMap type="DeviceIoe" id="DeviceIoeRM">
        <id property="deviceIoeIdx" column="device_ioe_idx" javaType="Long"></id><!--IOE장치식별자-->
        <result property="siteId" column="site_id" javaType="String"></result><!--사이트ID-->
        <result property="deviceId" column="device_id" javaType="String"></result><!--장치ID-->
        <result property="deviceName" column="device_name" javaType="String"></result><!--장치명-->
        <result property="deviceRegId" column="device_reg_id" javaType="String"></result><!--장치등록ID(UUID)-->
        <result property="serialNo" column="serial_no" javaType="String"></result><!--시리얼번호-->
        <result property="instType" column="inst_type" javaType="String"></result><!--설치구분(1:single-phase two-wires,2:single-phase three-wires,3:poly-phase three-wires,4:poly-phase four-wires,5:multi-channel,6:modem,7:plug,8:virtual device)-->
        <result property="instPurpose" column="inst_purpose" javaType="String"></result><!--설치목적(1:site consumption,2:appliance consumption,3:site generation,4:standalone consumption)-->
        <result property="dataPeriod" column="data_period" javaType="Integer"></result><!--데이터업로드주기(단위:초)-->
        <result property="dataCnt" column="data_cnt" javaType="Integer"></result><!--데이터업로드개수(단위:Hz)-->
        <result property="ctCapacity" column="ct_capacity" javaType="Integer"></result><!--CT용량합계(단위:A)-->
        <result property="ctCapacityList" column="ct_capacity_list" javaType="String"></result><!--CT용량리스트(여러개인 경우 콤마로 구분)-->
        <result property="pwCapacity" column="pw_capacity" javaType="Integer"></result><!--전력용량(단위:W)-->
        <result property="chCnt" column="ch_cnt" javaType="Integer"></result><!--채널수-->
        <result property="chPurpose" column="ch_purpose" javaType="String"></result><!--채널목적(여러개인 경우 콤마로 구분)-->
        <result property="provider" column="provider" javaType="String"></result><!--장치공급자-->
        <result property="vrDeviceId" column="vr_device_id" javaType="String"></result><!--가상장치ID-->
        <result property="vrDeviceGrpId" column="vr_device_grp_id" javaType="String"></result><!--가상장치그룹ID-->
        <result property="vrOwnerId" column="vr_owner_id" javaType="String"></result><!--가상장치소유자ID-->
        <result property="vrAction" column="vr_action" javaType="String"></result><!--가상장치액션-->
        <result property="vrStat" column="vr_stat" javaType="String"></result><!--가상장치상태-->
        <result property="vrModDate" column="vr_mod_date" javaType="Date"></result><!--가상장치업데이트일시-->
        <result property="vrError" column="vr_error" javaType="String"></result><!--가상장치에러(JSON형태)-->
        <result property="tmVoltage" column="tm_voltage" javaType="Integer"></result><!--TargetMeter 전압(단위:mV)-->
        <result property="tmPulse" column="tm_pulse" javaType="Integer"></result><!--TargetMeter 펄스(단위:pulse/kWh)-->
        <result property="tmCtRatio" column="tm_ct_ratio" javaType="Integer"></result><!--TargetMeter current transformation ratio-->
        <result property="tmPtTatio" column="tm_pt_tatio" javaType="Integer"></result><!--TargetMeter power transformation ratio-->
        <result property="networkConf" column="network_conf" javaType="String"></result><!--채널목적(JSON형태)-->
        <result property="options" column="options" javaType="String"></result><!--사용자정의데이터-->
        <result property="createTimestamp" column="create_timestamp" javaType="Date"></result><!--생성타임스탬프-->
        <result property="createDate" column="create_date" javaType="Date"></result><!--생성일시-->
        <result property="uploadTimestamp" column="upload_timestamp" javaType="Date"></result><!--업로드타임스탬프-->
        <result property="uploadDate" column="upload_date" javaType="Date"></result><!--업로드일시-->
        <result property="deviceStat" column="device_stat" javaType="String"></result><!--장치상태(1:connect,2:disconnect)-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
    </resultMap>
    <insert id="insert" parameterType="DeviceIoe">
        /* IOE장치 등록 */
        INSERT INTO tb_device_ioe (
               site_id,
               device_id,
               device_name,
               device_reg_id,
               serial_no,
               inst_type,
               inst_purpose,
               data_period,
               data_cnt,
               ct_capacity,
               ct_capacity_list,
               pw_capacity,
               ch_cnt,
               ch_purpose,
               provider,
               vr_device_id,
               vr_device_grp_id,
               vr_owner_id,
               vr_action,
               vr_stat,
               vr_mod_date,
               vr_error,
               tm_voltage,
               tm_pulse,
               tm_ct_ratio,
               tm_pt_tatio,
               network_conf,
               options,
               create_timestamp,
               create_date,
               upload_timestamp,
               upload_date,
               device_stat,
               reg_date
             ) VALUES (
               #{entity.siteId},
               #{entity.deviceId},
               #{entity.deviceName},
               #{entity.deviceRegId},
               #{entity.serialNo},
               #{entity.instType},
               #{entity.instPurpose},
               #{entity.dataPeriod},
               #{entity.dataCnt},
               #{entity.ctCapacity},
               #{entity.ctCapacityList},
               #{entity.pwCapacity},
               #{entity.chCnt},
               #{entity.chPurpose},
               #{entity.provider},
               #{entity.vrDeviceId},
               #{entity.vrDeviceGrpId},
               #{entity.vrOwnerId},
               #{entity.vrAction},
               #{entity.vrStat},
               #{entity.vrModDate},
               #{entity.vrError},
               #{entity.tmVoltage},
               #{entity.tmPulse},
               #{entity.tmCtRatio},
               #{entity.tmPtTatio},
               #{entity.networkConf},
               #{entity.options},
               #{entity.createTimestamp},
               #{entity.createDate},
               #{entity.uploadTimestamp},
               #{entity.uploadDate},
               #{entity.deviceStat},
               NOW())
        <selectKey resultType="Long" keyProperty="entity.deviceIoeIdx">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
    <update id="update" parameterType="DeviceIoe">
        /* IOE장치 수정 */
        UPDATE tb_device_ioe 
               <set>
               <if test="entity.siteId != null">
               site_id = #{entity.siteId},
               </if>
               <if test="entity.deviceId != null">
               device_id = #{entity.deviceId},
               </if>
               <if test="entity.deviceName != null">
               device_name = #{entity.deviceName},
               </if>
               <if test="entity.deviceRegId != null">
               device_reg_id = #{entity.deviceRegId},
               </if>
               <if test="entity.serialNo != null">
               serial_no = #{entity.serialNo},
               </if>
               <if test="entity.instType != null">
               inst_type = #{entity.instType},
               </if>
               <if test="entity.instPurpose != null">
               inst_purpose = #{entity.instPurpose},
               </if>
               <if test="entity.dataPeriod != null">
               data_period = #{entity.dataPeriod},
               </if>
               <if test="entity.dataCnt != null">
               data_cnt = #{entity.dataCnt},
               </if>
               <if test="entity.ctCapacity != null">
               ct_capacity = #{entity.ctCapacity},
               </if>
               <if test="entity.ctCapacityList != null">
               ct_capacity_list = #{entity.ctCapacityList},
               </if>
               <if test="entity.pwCapacity != null">
               pw_capacity = #{entity.pwCapacity},
               </if>
               <if test="entity.chCnt != null">
               ch_cnt = #{entity.chCnt},
               </if>
               <if test="entity.chPurpose != null">
               ch_purpose = #{entity.chPurpose},
               </if>
               <if test="entity.provider != null">
               provider = #{entity.provider},
               </if>
               <if test="entity.vrDeviceId != null">
               vr_device_id = #{entity.vrDeviceId},
               </if>
               <if test="entity.vrDeviceGrpId != null">
               vr_device_grp_id = #{entity.vrDeviceGrpId},
               </if>
               <if test="entity.vrOwnerId != null">
               vr_owner_id = #{entity.vrOwnerId},
               </if>
               <if test="entity.vrAction != null">
               vr_action = #{entity.vrAction},
               </if>
               <if test="entity.vrStat != null">
               vr_stat = #{entity.vrStat},
               </if>
               <if test="entity.vrModDate != null">
               vr_mod_date = #{entity.vrModDate},
               </if>
               <if test="entity.vrError != null">
               vr_error = #{entity.vrError},
               </if>
               <if test="entity.tmVoltage != null">
               tm_voltage = #{entity.tmVoltage},
               </if>
               <if test="entity.tmPulse != null">
               tm_pulse = #{entity.tmPulse},
               </if>
               <if test="entity.tmCtRatio != null">
               tm_ct_ratio = #{entity.tmCtRatio},
               </if>
               <if test="entity.tmPtTatio != null">
               tm_pt_tatio = #{entity.tmPtTatio},
               </if>
               <if test="entity.networkConf != null">
               network_conf = #{entity.networkConf},
               </if>
               <if test="entity.options != null">
               options = #{entity.options},
               </if>
               <if test="entity.createTimestamp != null">
               create_timestamp = #{entity.createTimestamp},
               </if>
               <if test="entity.createDate != null">
               create_date = #{entity.createDate},
               </if>
               <if test="entity.uploadTimestamp != null">
               upload_timestamp = #{entity.uploadTimestamp},
               </if>
               <if test="entity.uploadDate != null">
               upload_date = #{entity.uploadDate},
               </if>
               <if test="entity.deviceStat != null">
               device_stat = #{entity.deviceStat},
               </if>
               <if test="entity.regDate != null">
               reg_date = #{entity.regDate},
               </if>
               </set>
         WHERE device_ioe_idx = #{entity.deviceIoeIdx}
    </update>
    <delete id="delete" parameterType="DeviceIoe">
        /* IOE장치 삭제 */
        DELETE FROM tb_device_ioe 
         WHERE device_ioe_idx = #{deviceIoeIdx}
    </delete>
    <select id="selectOne" resultMap="DeviceIoeRM">
        /* IOE장치 상세조회 */
        SELECT device_ioe_idx,
               site_id,
               device_id,
               device_name,
               device_reg_id,
               serial_no,
               inst_type,
               inst_purpose,
               data_period,
               data_cnt,
               ct_capacity,
               ct_capacity_list,
               pw_capacity,
               ch_cnt,
               ch_purpose,
               provider,
               vr_device_id,
               vr_device_grp_id,
               vr_owner_id,
               vr_action,
               vr_stat,
               vr_mod_date,
               vr_error,
               tm_voltage,
               tm_pulse,
               tm_ct_ratio,
               tm_pt_tatio,
               network_conf,
               options,
               create_timestamp,
               create_date,
               upload_timestamp,
               upload_date,
               device_stat,
               reg_date
          FROM tb_device_ioe
         WHERE device_ioe_idx = #{deviceIoeIdx}
    </select>
    <select id="selectList" resultMap="DeviceIoeRM">
        /* IOE장치 목록조회 */
        SELECT device_ioe_idx,
               site_id,
               device_id,
               device_name,
               device_reg_id,
               serial_no,
               inst_type,
               inst_purpose,
               data_period,
               data_cnt,
               ct_capacity,
               ct_capacity_list,
               pw_capacity,
               ch_cnt,
               ch_purpose,
               provider,
               vr_device_id,
               vr_device_grp_id,
               vr_owner_id,
               vr_action,
               vr_stat,
               vr_mod_date,
               vr_error,
               tm_voltage,
               tm_pulse,
               tm_ct_ratio,
               tm_pt_tatio,
               network_conf,
               options,
               create_timestamp,
               create_date,
               upload_timestamp,
               upload_date,
               device_stat,
               reg_date
          FROM tb_device_ioe
               <if test="pageable != null">
         WHERE LIMIT #{pageable.start}, #{pageable.end}
               </if>
    </select>
    <select id="selectListCount" resultType="int">
        /* IOE장치 전체 개수 조회 */
        SELECT COUNT(*) AS CNT
          FROM tb_device_ioe
         WHERE device_ioe_idx = #{deviceIoeIdx}
    </select>
</mapper>