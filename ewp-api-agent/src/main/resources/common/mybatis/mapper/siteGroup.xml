<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ewp.api.dao.SiteGroupDao">
    <resultMap type="SiteGroup" id="SiteGroupRM">
        <id property="siteGrpIdx" column="site_grp_idx" javaType="Integer"></id><!--사이트그룹식별자-->
        <result property="userIdx" column="user_idx" javaType="Integer"></result><!--사용자식별자-->
        <result property="siteGrpName" column="site_grp_name" javaType="String"></result><!--사이트그룹명-->
        <result property="delYn" column="del_yn" javaType="String"></result><!--삭제여부(Y:예,N:아니오)-->
        <result property="regUid" column="reg_uid" javaType="String"></result><!--등록자ID-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
        <result property="modUid" column="mod_uid" javaType="String"></result><!--최종수정자ID-->
        <result property="modDate" column="mod_date" javaType="Date"></result><!--최종수정일시-->
    </resultMap>
    <insert id="insert" parameterType="SiteGroup">
        /* 사이트그룹 등록 */
        INSERT INTO tb_site_group (
               user_idx,
               site_grp_name,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
             ) VALUES (
               #{entity.userIdx},
               #{entity.siteGrpName},
               #{entity.delYn},
               #{entity.regUid},
               #{entity.regDate},
               #{entity.modUid},
               #{entity.modDate})
        <selectKey resultType="Integer" keyProperty="entity.siteGrpIdx">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
    <update id="update" parameterType="SiteGroup">
        /* 사이트그룹 수정 */
        UPDATE tb_site_group 
               <set>
               <if test="entity.userIdx != null">
               user_idx = #{entity.userIdx},
               </if>
               <if test="entity.siteGrpName != null">
               site_grp_name = #{entity.siteGrpName},
               </if>
               <if test="entity.delYn != null">
               del_yn = #{entity.delYn},
               </if>
               <if test="entity.regUid != null">
               reg_uid = #{entity.regUid},
               </if>
               <if test="entity.regDate != null">
               reg_date = #{entity.regDate},
               </if>
               <if test="entity.modUid != null">
               mod_uid = #{entity.modUid},
               </if>
               <if test="entity.modDate != null">
               mod_date = #{entity.modDate},
               </if>
               </set>
         WHERE site_grp_idx = #{entity.siteGrpIdx}
    </update>
    <delete id="delete" parameterType="SiteGroup">
        /* 사이트그룹 삭제 */
        DELETE FROM tb_site_group 
         WHERE site_grp_idx = #{siteGrpIdx}
    </delete>
    <select id="selectOne" resultMap="SiteGroupRM">
        /* 사이트그룹 상세조회 */
        SELECT site_grp_idx,
               user_idx,
               site_grp_name,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_site_group
         WHERE site_grp_idx = #{siteGrpIdx}
    </select>
    <select id="selectList" resultMap="SiteGroupRM">
        /* 사이트그룹 목록조회 */
        SELECT site_grp_idx,
               user_idx,
               site_grp_name,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_site_group
               <if test="pageable != null">
         WHERE LIMIT #{pageable.start}, #{pageable.end}
               </if>
    </select>
    <select id="selectListCount" resultType="int">
        /* 사이트그룹 전체 개수 조회 */
        SELECT COUNT(*) AS CNT
          FROM tb_site_group
         WHERE site_grp_idx = #{siteGrpIdx}
    </select>
</mapper>