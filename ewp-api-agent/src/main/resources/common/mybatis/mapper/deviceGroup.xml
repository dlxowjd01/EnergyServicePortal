<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ewp.api.dao.DeviceGroupDao">
    <resultMap type="DeviceGroup" id="DeviceGroupRM">
        <id property="deviceGrpIdx" column="device_grp_idx" javaType="Integer"></id><!--장치그룹식별자-->
        <result property="siteId" column="site_id" javaType="String"></result><!--사이트ID-->
        <result property="userIdx" column="user_idx" javaType="Integer"></result><!--사용자식별자-->
        <result property="deviceGrpName" column="device_grp_name" javaType="String"></result><!--장치그룹명-->
        <result property="delYn" column="del_yn" javaType="String"></result><!--삭제여부(Y:예,N:아니오)-->
        <result property="regUid" column="reg_uid" javaType="String"></result><!--등록자ID-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
        <result property="modUid" column="mod_uid" javaType="String"></result><!--최종수정자ID-->
        <result property="modDate" column="mod_date" javaType="Date"></result><!--최종수정일시-->
    </resultMap>
    <insert id="insert" parameterType="DeviceGroup">
        /* 장치그룹 등록 */
        INSERT INTO tb_device_group (
               site_id,
               user_idx,
               device_grp_name,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
             ) VALUES (
               #{entity.siteId},
               #{entity.userIdx},
               #{entity.deviceGrpName},
               #{entity.delYn},
               #{entity.regUid},
               #{entity.regDate},
               #{entity.modUid},
               #{entity.modDate})
        <selectKey resultType="Integer" keyProperty="entity.deviceGrpIdx">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
    <update id="update" parameterType="DeviceGroup">
        /* 장치그룹 수정 */
        UPDATE tb_device_group 
               <set>
               <if test="entity.siteId != null">
               site_id = #{entity.siteId},
               </if>
               <if test="entity.userIdx != null">
               user_idx = #{entity.userIdx},
               </if>
               <if test="entity.deviceGrpName != null">
               device_grp_name = #{entity.deviceGrpName},
               </if>
               <if test="entity.delYn != null">
               del_yn = #{entity.delYn},
               </if>
               <if test="entity.regUid != null">
               reg_uid = #{entity.regUid},
               </if>
               <if test="entity.regDate != null">
               reg_date = #{entity.regDate},
               </if>
               <if test="entity.modUid != null">
               mod_uid = #{entity.modUid},
               </if>
               <if test="entity.modDate != null">
               mod_date = #{entity.modDate},
               </if>
               </set>
         WHERE device_grp_idx = #{entity.deviceGrpIdx}
    </update>
    <delete id="delete" parameterType="DeviceGroup">
        /* 장치그룹 삭제 */
        DELETE FROM tb_device_group 
         WHERE device_grp_idx = #{deviceGrpIdx}
    </delete>
    <select id="selectOne" resultMap="DeviceGroupRM">
        /* 장치그룹 상세조회 */
        SELECT device_grp_idx,
               site_id,
               user_idx,
               device_grp_name,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_device_group
         WHERE device_grp_idx = #{deviceGrpIdx}
    </select>
    <select id="selectList" resultMap="DeviceGroupRM">
        /* 장치그룹 목록조회 */
        SELECT device_grp_idx,
               site_id,
               user_idx,
               device_grp_name,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_device_group
               <if test="pageable != null">
         WHERE LIMIT #{pageable.start}, #{pageable.end}
               </if>
    </select>
    <select id="selectListCount" resultType="int">
        /* 장치그룹 전체 개수 조회 */
        SELECT COUNT(*) AS CNT
          FROM tb_device_group
         WHERE device_grp_idx = #{deviceGrpIdx}
    </select>
</mapper>