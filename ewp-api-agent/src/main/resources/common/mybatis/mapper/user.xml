<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ewp.api.dao.UserDao">
    <resultMap type="User" id="UserRM">
        <id property="userIdx" column="user_idx" javaType="Integer"></id><!--사용자식별자-->
        <result property="userId" column="user_id" javaType="String"></result><!--아이디-->
        <result property="userPw" column="user_pw" javaType="String"></result><!--패스워드-->
        <result property="userType" column="user_type" javaType="String"></result><!--사용자구분(1:동서발전,2:고객사)-->
        <result property="mainUserIdx" column="main_user_idx" javaType="Integer"></result><!--주사용자식별자-->
        <result property="mainUserYn" column="main_user_yn" javaType="String"></result><!--주사용자여부(Y:예,N:아니오)-->
        <result property="authType" column="auth_type" javaType="String"></result><!--권한구분(1:포털관리자,2:그룹관리자,3:사이트관리자,4:사이트이용자)-->
        <result property="langType" column="lang_type" javaType="String"></result><!--언어구분(1:한국어,2:영어,3:일본어)-->
        <result property="coName" column="co_name" javaType="String"></result><!--고객사명-->
        <result property="coTel" column="co_tel" javaType="String"></result><!--회사전화번호-->
        <result property="coEmail" column="co_email" javaType="String"></result><!--회사이메일주소-->
        <result property="psnName" column="psn_name" javaType="String"></result><!--담당자명-->
        <result property="psnDept" column="psn_dept" javaType="String"></result><!--담당자부서-->
        <result property="psnTel" column="psn_tel" javaType="String"></result><!--담당자전화번호-->
        <result property="psnMobile" column="psn_mobile" javaType="String"></result><!--담당자휴대폰번호-->
        <result property="psnEmail" column="psn_email" javaType="String"></result><!--담당자이메일주소-->
        <result property="note" column="note" javaType="String"></result><!--비고-->
        <result property="delYn" column="del_yn" javaType="String"></result><!--삭제여부(Y:예,N:아니오)-->
        <result property="regUid" column="reg_uid" javaType="String"></result><!--등록자ID-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
        <result property="modUid" column="mod_uid" javaType="String"></result><!--최종수정자ID-->
        <result property="modDate" column="mod_date" javaType="Date"></result><!--최종수정일시-->
    </resultMap>
    <insert id="insert" parameterType="User">
        /* 사용자 등록 */
        INSERT INTO tb_user (
               user_id,
               user_pw,
               user_type,
               main_user_idx,
               main_user_yn,
               auth_type,
               lang_type,
               co_name,
               co_tel,
               co_email,
               psn_name,
               psn_dept,
               psn_tel,
               psn_mobile,
               psn_email,
               note,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
             ) VALUES (
               #{entity.userId},
               #{entity.userPw},
               #{entity.userType},
               #{entity.mainUserIdx},
               #{entity.mainUserYn},
               #{entity.authType},
               #{entity.langType},
               #{entity.coName},
               #{entity.coTel},
               #{entity.coEmail},
               #{entity.psnName},
               #{entity.psnDept},
               #{entity.psnTel},
               #{entity.psnMobile},
               #{entity.psnEmail},
               #{entity.note},
               #{entity.delYn},
               #{entity.regUid},
               #{entity.regDate},
               #{entity.modUid},
               #{entity.modDate})
        <selectKey resultType="Integer" keyProperty="entity.userIdx">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
    <update id="update" parameterType="User">
        /* 사용자 수정 */
        UPDATE tb_user 
               <set>
               <if test="entity.userId != null">
               user_id = #{entity.userId},
               </if>
               <if test="entity.userPw != null">
               user_pw = #{entity.userPw},
               </if>
               <if test="entity.userType != null">
               user_type = #{entity.userType},
               </if>
               <if test="entity.mainUserIdx != null">
               main_user_idx = #{entity.mainUserIdx},
               </if>
               <if test="entity.mainUserYn != null">
               main_user_yn = #{entity.mainUserYn},
               </if>
               <if test="entity.authType != null">
               auth_type = #{entity.authType},
               </if>
               <if test="entity.langType != null">
               lang_type = #{entity.langType},
               </if>
               <if test="entity.coName != null">
               co_name = #{entity.coName},
               </if>
               <if test="entity.coTel != null">
               co_tel = #{entity.coTel},
               </if>
               <if test="entity.coEmail != null">
               co_email = #{entity.coEmail},
               </if>
               <if test="entity.psnName != null">
               psn_name = #{entity.psnName},
               </if>
               <if test="entity.psnDept != null">
               psn_dept = #{entity.psnDept},
               </if>
               <if test="entity.psnTel != null">
               psn_tel = #{entity.psnTel},
               </if>
               <if test="entity.psnMobile != null">
               psn_mobile = #{entity.psnMobile},
               </if>
               <if test="entity.psnEmail != null">
               psn_email = #{entity.psnEmail},
               </if>
               <if test="entity.note != null">
               note = #{entity.note},
               </if>
               <if test="entity.delYn != null">
               del_yn = #{entity.delYn},
               </if>
               <if test="entity.regUid != null">
               reg_uid = #{entity.regUid},
               </if>
               <if test="entity.regDate != null">
               reg_date = #{entity.regDate},
               </if>
               <if test="entity.modUid != null">
               mod_uid = #{entity.modUid},
               </if>
               <if test="entity.modDate != null">
               mod_date = #{entity.modDate},
               </if>
               </set>
         WHERE user_idx = #{entity.userIdx}
    </update>
    <delete id="delete" parameterType="User">
        /* 사용자 삭제 */
        DELETE FROM tb_user 
         WHERE user_idx = #{userIdx}
    </delete>
    <select id="selectOne" resultMap="UserRM">
        /* 사용자 상세조회 */
        SELECT user_idx,
               user_id,
               user_pw,
               user_type,
               main_user_idx,
               main_user_yn,
               auth_type,
               lang_type,
               co_name,
               co_tel,
               co_email,
               psn_name,
               psn_dept,
               psn_tel,
               psn_mobile,
               psn_email,
               note,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_user
         WHERE user_idx = #{userIdx}
    </select>
    <select id="selectList" resultMap="UserRM">
        /* 사용자 목록조회 */
        SELECT user_idx,
               user_id,
               user_pw,
               user_type,
               main_user_idx,
               main_user_yn,
               auth_type,
               lang_type,
               co_name,
               co_tel,
               co_email,
               psn_name,
               psn_dept,
               psn_tel,
               psn_mobile,
               psn_email,
               note,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_user
               <if test="pageable != null">
         WHERE LIMIT #{pageable.start}, #{pageable.end}
               </if>
    </select>
    <select id="selectListCount" resultType="int">
        /* 사용자 전체 개수 조회 */
        SELECT COUNT(*) AS CNT
          FROM tb_user
         WHERE user_idx = #{userIdx}
    </select>
</mapper>