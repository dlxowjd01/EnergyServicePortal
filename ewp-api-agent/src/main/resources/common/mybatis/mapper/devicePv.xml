<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ewp.api.dao.DevicePvDao">
    <resultMap type="DevicePv" id="DevicePvRM">
        <id property="devicePvIdx" column="device_pv_idx" javaType="Long"></id><!--PV장치식별자-->
        <result property="siteId" column="site_id" javaType="String"></result><!--사이트ID-->
        <result property="deviceId" column="device_id" javaType="String"></result><!--장치ID-->
        <result property="deviceName" column="device_name" javaType="String"></result><!--장치명-->
        <result property="deviceStat" column="device_stat" javaType="String"></result><!--PV상태-->
        <result property="alarmMsg" column="alarm_msg" javaType="String"></result><!--알람메시지-->
        <result property="acVoltage" column="ac_voltage" javaType="Integer"></result><!--AC출력 - 전압(단위:V)-->
        <result property="acPower" column="ac_power" javaType="Integer"></result><!--AC출력 - 전력(단위:kWh)-->
        <result property="acCurrent" column="ac_current" javaType="Integer"></result><!--AC출력 - 전류(단위:A)-->
        <result property="acFreq" column="ac_freq" javaType="Integer"></result><!--AC출력 - 주파수(단위:Hz)-->
        <result property="dcVoltage" column="dc_voltage" javaType="Integer"></result><!--DC출력 - 전압(단위:V)-->
        <result property="dcPower" column="dc_power" javaType="Integer"></result><!--DC출력 - 전력(단위:kWh)-->
        <result property="dcCurrent" column="dc_current" javaType="Integer"></result><!--DC출력 - 전류(단위:A)-->
        <result property="dcFreq" column="dc_freq" javaType="Integer"></result><!--DC출력 - 주파수(단위:Hz)-->
        <result property="temp" column="temp" javaType="Integer"></result><!--온도(단위:℃)-->
        <result property="totPower" column="tot_power" javaType="Integer"></result><!--금일누적발전량(단위:kWh)-->
        <result property="todayGenPower" column="today_gen_power" javaType="Integer"></result><!--Today generated energy (Wh)-->
        <result property="totalGenPower" column="total_gen_power" javaType="Integer"></result><!--Accumulated generated energy (Wh)-->
        <result property="stdDate" column="std_date" javaType="Date"></result><!--기준일시-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
    </resultMap>
    <insert id="insert" parameterType="DevicePv">
        /* PV장치 등록 */
        INSERT INTO tb_device_pv (
               site_id,
               device_id,
               device_name,
               device_stat,
               alarm_msg,
               ac_voltage,
               ac_power,
               ac_current,
               ac_freq,
               dc_voltage,
               dc_power,
               dc_current,
               dc_freq,
               temp,
               tot_power,
               today_gen_power,
               total_gen_power,
               std_date,
               reg_date
             ) VALUES (
               #{entity.siteId},
               #{entity.deviceId},
               #{entity.deviceName},
               #{entity.deviceStat},
               #{entity.alarmMsg},
               #{entity.acVoltage},
               #{entity.acPower},
               #{entity.acCurrent},
               #{entity.acFreq},
               #{entity.dcVoltage},
               #{entity.dcPower},
               #{entity.dcCurrent},
               #{entity.dcFreq},
               #{entity.temp},
               #{entity.totPower},
               #{entity.todayGenPower},
               #{entity.totalGenPower},
               #{entity.stdDate},
               NOW())
        <selectKey resultType="Long" keyProperty="entity.devicePvIdx">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
    <update id="update" parameterType="DevicePv">
        /* PV장치 수정 */
        UPDATE tb_device_pv 
               <set>
               <if test="entity.siteId != null">
               site_id = #{entity.siteId},
               </if>
               <if test="entity.deviceId != null">
               device_id = #{entity.deviceId},
               </if>
               <if test="entity.deviceName != null">
               device_name = #{entity.deviceName},
               </if>
               <if test="entity.deviceStat != null">
               device_stat = #{entity.deviceStat},
               </if>
               <if test="entity.alarmMsg != null">
               alarm_msg = #{entity.alarmMsg},
               </if>
               <if test="entity.acVoltage != null">
                   ac_voltage = #{entity.acVoltage},
               </if>
               <if test="entity.acPower != null">
                   ac_power = #{entity.acPower},
               </if>
               <if test="entity.acCurrent != null">
                   ac_current = #{entity.acCurrent},
               </if>
               <if test="entity.acFreq != null">
                   ac_freq = #{entity.acFreq},
               </if>
               <if test="entity.dcVoltage != null">
                   dc_voltage = #{entity.dcVoltage},
               </if>
               <if test="entity.dcPower != null">
                   dc_power = #{entity.dcPower},
               </if>
               <if test="entity.dcCurrent != null">
                   dc_current = #{entity.dcCurrent},
               </if>
               <if test="entity.dcFreq != null">
                   dc_freq = #{entity.dcFreq},
               </if>
               <if test="entity.temp != null">
               temp = #{entity.temp},
               </if>
               <if test="entity.totPower != null">
               tot_power = #{entity.totPower},
               </if>
               <if test="entity.todayGenPower != null">
                   today_gen_power = #{entity.todayGenPower},
               </if>
               <if test="entity.totalGenPower != null">
                   total_gen_power = #{entity.totalGenPower},
               </if>
               <if test="entity.stdDate != null">
               std_date = #{entity.stdDate},
               </if>
               <if test="entity.regDate != null">
               reg_date = #{entity.regDate},
               </if>
               </set>
         WHERE device_pv_idx = #{entity.devicePvIdx}
    </update>
    <delete id="delete" parameterType="DevicePv">
        /* PV장치 삭제 */
        DELETE FROM tb_device_pv 
         WHERE device_pv_idx = #{devicePvIdx}
    </delete>
    <select id="selectOne" resultMap="DevicePvRM">
        /* PV장치 상세조회 */
        SELECT device_pv_idx,
               site_id,
               device_id,
               device_name,
               device_stat,
               alarm_msg,
               ac_voltage,
               ac_power,
               ac_current,
               ac_freq,
               dc_voltage,
               dc_power,
               dc_current,
               dc_freq,
               temp,
               tot_power,
               today_gen_power,
               total_gen_power,
               std_date,
               reg_date
          FROM tb_device_pv
         WHERE device_pv_idx = #{devicePvIdx}
    </select>
    <select id="selectList" resultMap="DevicePvRM">
        /* PV장치 목록조회 */
        SELECT device_pv_idx,
               site_id,
               device_id,
               device_name,
               device_stat,
               alarm_msg,
                ac_voltage,
                ac_power,
                ac_current,
                ac_freq,
                dc_voltage,
                dc_power,
                dc_current,
                dc_freq,
                temp,
                tot_power,
                today_gen_power,
                total_gen_power,
               std_date,
               reg_date
          FROM tb_device_pv
               <if test="pageable != null">
         WHERE LIMIT #{pageable.start}, #{pageable.end}
               </if>
    </select>
    <select id="selectListCount" resultType="int">
        /* PV장치 전체 개수 조회 */
        SELECT COUNT(*) AS CNT
          FROM tb_device_pv
         WHERE device_pv_idx = #{devicePvIdx}
    </select>
</mapper>