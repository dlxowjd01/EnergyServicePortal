<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ewp.api.dao.DevicePvDao">
    <resultMap type="DevicePv" id="DevicePvRM">
        <id property="devicePvIdx" column="device_pv_idx" javaType="Long"></id><!--PV장치식별자-->
        <result property="siteId" column="site_id" javaType="String"></result><!--사이트ID-->
        <result property="deviceId" column="device_id" javaType="String"></result><!--장치ID-->
        <result property="deviceName" column="device_name" javaType="String"></result><!--장치명-->
        <result property="deviceStat" column="device_stat" javaType="String"></result><!--PV상태-->
        <result property="alarmMsg" column="alarm_msg" javaType="String"></result><!--알람메시지-->
        <result property="temp" column="temp" javaType="Integer"></result><!--온도(단위:℃)-->
        <result property="totPower" column="tot_power" javaType="Integer"></result><!--금일누적발전량(단위:kWh)-->
        <result property="stdDate" column="std_date" javaType="Date"></result><!--기준일시-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
    </resultMap>
    <insert id="insert" parameterType="DevicePv">
        /* PV장치 등록 */
        INSERT INTO tb_device_pv (
               site_id,
               device_id,
               device_name,
               device_stat,
               alarm_msg,
               temp,
               tot_power,
               std_date,
               reg_date
             ) VALUES (
               #{entity.siteId},
               #{entity.deviceId},
               #{entity.deviceName},
               #{entity.deviceStat},
               #{entity.alarmMsg},
               #{entity.temp},
               #{entity.totPower},
               #{entity.stdDate},
               NOW())
        <selectKey resultType="Long" keyProperty="entity.devicePvIdx">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
    <update id="update" parameterType="DevicePv">
        /* PV장치 수정 */
        UPDATE tb_device_pv 
               <set>
               <if test="entity.siteId != null">
               site_id = #{entity.siteId},
               </if>
               <if test="entity.deviceId != null">
               device_id = #{entity.deviceId},
               </if>
               <if test="entity.deviceName != null">
               device_name = #{entity.deviceName},
               </if>
               <if test="entity.deviceStat != null">
               device_stat = #{entity.deviceStat},
               </if>
               <if test="entity.alarmMsg != null">
               alarm_msg = #{entity.alarmMsg},
               </if>
               <if test="entity.temp != null">
               temp = #{entity.temp},
               </if>
               <if test="entity.totPower != null">
               tot_power = #{entity.totPower},
               </if>
               <if test="entity.stdDate != null">
               std_date = #{entity.stdDate},
               </if>
               <if test="entity.regDate != null">
               reg_date = #{entity.regDate},
               </if>
               </set>
         WHERE device_pv_idx = #{entity.devicePvIdx}
    </update>
    <delete id="delete" parameterType="DevicePv">
        /* PV장치 삭제 */
        DELETE FROM tb_device_pv 
         WHERE device_pv_idx = #{devicePvIdx}
    </delete>
    <select id="selectOne" resultMap="DevicePvRM">
        /* PV장치 상세조회 */
        SELECT device_pv_idx,
               site_id,
               device_id,
               device_name,
               device_stat,
               alarm_msg,
               temp,
               tot_power,
               std_date,
               reg_date
          FROM tb_device_pv
         WHERE device_pv_idx = #{devicePvIdx}
    </select>
    <select id="selectList" resultMap="DevicePvRM">
        /* PV장치 목록조회 */
        SELECT device_pv_idx,
               site_id,
               device_id,
               device_name,
               device_stat,
               alarm_msg,
               temp,
               tot_power,
               std_date,
               reg_date
          FROM tb_device_pv
               <if test="pageable != null">
         WHERE LIMIT #{pageable.start}, #{pageable.end}
               </if>
    </select>
    <select id="selectListCount" resultType="int">
        /* PV장치 전체 개수 조회 */
        SELECT COUNT(*) AS CNT
          FROM tb_device_pv
         WHERE device_pv_idx = #{devicePvIdx}
    </select>
</mapper>