<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ewp.api.dao.DevicePcsDao">
    <resultMap type="DevicePcs" id="DevicePcsRM">
        <id property="devicePcsIdx" column="device_pcs_idx" javaType="Long"></id><!--PCS장치식별자-->
        <result property="siteId" column="site_id" javaType="String"></result><!--사이트ID-->
        <result property="deviceId" column="device_id" javaType="String"></result><!--장치ID-->
        <result property="deviceName" column="device_name" javaType="String"></result><!--장치명-->
        <result property="deviceStat" column="device_stat" javaType="String"></result><!--운전상태-->
        <result property="alarmMsg" column="alarm_msg" javaType="String"></result><!--알람메시지-->
        <result property="acVoltage" column="ac_voltage" javaType="Integer"></result><!--AC출력 - 전압(단위:V)-->
        <result property="acPower" column="ac_power" javaType="Integer"></result><!--AC출력 - 전력(단위:kWh)-->
        <result property="acCurrent" column="ac_current" javaType="Integer"></result><!--AC출력 - 전류(단위:A)-->
        <result property="acFreq" column="ac_freq" javaType="Integer"></result><!--AC출력 - 주파수(단위:Hz)-->
        <result property="acSetPower" column="ac_set_power" javaType="Integer"></result><!--AC출력 - 전력설정치(단위:kWh)-->
        <result property="acPf" column="ac_pf" javaType="Integer"></result><!--AC출력 - 역률-->
        <result property="dcVoltage" column="dc_voltage" javaType="Integer"></result><!--DC출력 - 전압(단위:V)-->
        <result property="dcPower" column="dc_power" javaType="Integer"></result><!--DC출력 - 전력(단위:kWh)-->
        <result property="dcCurrent" column="dc_current" javaType="Integer"></result><!--DC출력 - 전류(단위:A)-->
        <result property="dcFreq" column="dc_freq" javaType="Integer"></result><!--DC출력 - 주파수(단위:Hz)-->
        <result property="dcSetPower" column="dc_set_power" javaType="Integer"></result><!--DC출력 - 전력설정치(단위:kWh)-->
        <result property="dcPf" column="dc_pf" javaType="Integer"></result><!--DC출력 - 역률-->
        <result property="stdDate" column="std_date" javaType="Date"></result><!--기준일시-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
        
        <result property="pcsStatus" column="pcs_status" javaType="String"></result>
        <result property="remoteMode" column="remote_mode" javaType="String"></result>
        <result property="pcsCommand" column="pcs_command" javaType="String"></result>
        <result property="todayDEnergy" column="today_d_energy" javaType="String"></result>
        <result property="todayCEnergy" column="today_c_energy" javaType="String"></result>
        <result property="totalDEnergy" column="total_d_energy" javaType="String"></result>
        <result property="totalCEnerge" column="total_c_energe" javaType="String"></result>
    </resultMap>
    <insert id="insert" parameterType="DevicePcs">
        /* PCS장치 등록 */
        INSERT INTO tb_device_pcs (
               site_id,
               device_id,
               device_name,
               device_stat,
               alarm_msg,
               ac_voltage,
               ac_power,
               ac_current,
               ac_freq,
               ac_set_power,
               ac_pf,
               dc_voltage,
               dc_power,
               dc_current,
               dc_freq,
               dc_set_power,
               dc_pf,
               pcs_status,
               remote_mode,
               pcs_command,
               today_d_energy,
               today_c_energy,
               total_d_energy,
               total_c_energe,
               std_date,
               reg_date
             ) VALUES (
               #{entity.siteId},
               #{entity.deviceId},
               #{entity.deviceName},
               #{entity.deviceStat},
               #{entity.alarmMsg},
               #{entity.acVoltage},
               #{entity.acPower},
               #{entity.acCurrent},
               #{entity.acFreq},
               #{entity.acSetPower},
               #{entity.acPf},
               #{entity.dcVoltage},
               #{entity.dcPower},
               #{entity.dcCurrent},
               #{entity.dcFreq},
               #{entity.dcSetPower},
               #{entity.dcPf},
               #{entity.pcsStatus},
               #{entity.remoteMode},
               #{entity.pcsCommand},
               #{entity.todayDEnergy},
               #{entity.todayCEnergy},
               #{entity.totalDEnergy},
               #{entity.totalCEnerge},
               #{entity.stdDate},
               NOW())
        <selectKey resultType="Long" keyProperty="entity.devicePcsIdx">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
    <update id="update" parameterType="DevicePcs">
        /* PCS장치 수정 */
        UPDATE tb_device_pcs 
               <set>
               <if test="entity.siteId != null">
               site_id = #{entity.siteId},
               </if>
               <if test="entity.deviceId != null">
               device_id = #{entity.deviceId},
               </if>
               <if test="entity.deviceName != null">
               device_name = #{entity.deviceName},
               </if>
               <if test="entity.deviceStat != null">
               device_stat = #{entity.deviceStat},
               </if>
               <if test="entity.alarmMsg != null">
               alarm_msg = #{entity.alarmMsg},
               </if>
               <if test="entity.acVoltage != null">
               ac_voltage = #{entity.acVoltage},
               </if>
               <if test="entity.acPower != null">
               ac_power = #{entity.acPower},
               </if>
               <if test="entity.acCurrent != null">
               ac_current = #{entity.acCurrent},
               </if>
               <if test="entity.acFreq != null">
               ac_freq = #{entity.acFreq},
               </if>
               <if test="entity.acSetPower != null">
               ac_set_power = #{entity.acSetPower},
               </if>
               <if test="entity.acPf != null">
               ac_pf = #{entity.acPf},
               </if>
               <if test="entity.dcVoltage != null">
               dc_voltage = #{entity.dcVoltage},
               </if>
               <if test="entity.dcPower != null">
               dc_power = #{entity.dcPower},
               </if>
               <if test="entity.dcCurrent != null">
               dc_current = #{entity.dcCurrent},
               </if>
               <if test="entity.dcFreq != null">
               dc_freq = #{entity.dcFreq},
               </if>
               <if test="entity.dcSetPower != null">
               dc_set_power = #{entity.dcSetPower},
               </if>
               <if test="entity.dcPf != null">
               dc_pf = #{entity.dcPf},
               </if>
               <if test="entity.stdDate != null">
               std_date = #{entity.stdDate},
               </if>
               
               <if test="entity.pcsStatus != null">
               pcs_status = #{entity.pcsStatus},
               </if>
               <if test="entity.remoteMode != null">
               remote_mode = #{entity.remoteMode},
               </if>
               <if test="entity.pcsCommand != null">
               pcs_command = #{entity.pcsCommand},
               </if>
               <if test="entity.todayDEnergy != null">
               today_d_energy = #{entity.todayDEnergy},
               </if>
               <if test="entity.todayCEnergy != null">
               today_c_energy = #{entity.todayCEnergy},
               </if>
               <if test="entity.totalDEnergy != null">
               total_d_energy = #{entity.totalDEnergy},
               </if>
               <if test="entity.totalCEnerge != null">
               total_c_energe = #{entity.totalCEnerge},
               </if>
               
               <if test="entity.regDate != null">
               reg_date = #{entity.regDate},
               </if>
               </set>
         WHERE device_pcs_idx = #{entity.devicePcsIdx}
    </update>
    <delete id="delete" parameterType="DevicePcs">
        /* PCS장치 삭제 */
        DELETE FROM tb_device_pcs 
         WHERE device_pcs_idx = #{devicePcsIdx}
    </delete>
    <select id="selectOne" resultMap="DevicePcsRM">
        /* PCS장치 상세조회 */
        SELECT device_pcs_idx,
               site_id,
               device_id,
               device_name,
               device_stat,
               alarm_msg,
               ac_voltage,
               ac_power,
               ac_current,
               ac_freq,
               ac_set_power,
               ac_pf,
               dc_voltage,
               dc_power,
               dc_current,
               dc_freq,
               dc_set_power,
               dc_pf,
               std_date,
               reg_date
          FROM tb_device_pcs
         WHERE device_pcs_idx = #{devicePcsIdx}
    </select>
    <select id="selectList" resultMap="DevicePcsRM">
        /* PCS장치 목록조회 */
        SELECT device_pcs_idx,
               site_id,
               device_id,
               device_name,
               device_stat,
               alarm_msg,
               ac_voltage,
               ac_power,
               ac_current,
               ac_freq,
               ac_set_power,
               ac_pf,
               dc_voltage,
               dc_power,
               dc_current,
               dc_freq,
               dc_set_power,
               dc_pf,
               std_date,
               reg_date
          FROM tb_device_pcs
               <if test="pageable != null">
         WHERE LIMIT #{pageable.start}, #{pageable.end}
               </if>
    </select>
    <select id="selectListCount" resultType="int">
        /* PCS장치 전체 개수 조회 */
        SELECT COUNT(*) AS CNT
          FROM tb_device_pcs
         WHERE device_pcs_idx = #{devicePcsIdx}
    </select>
</mapper>