<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ewp.api.dao.FaqDao">
    <resultMap type="Faq" id="FaqRM">
        <id property="faqIdx" column="faq_idx" javaType="Integer"></id><!--자주하는질문식별자-->
        <result property="question" column="question" javaType="String"></result><!--질문-->
        <result property="answer" column="answer" javaType="String"></result><!--답변-->
        <result property="delYn" column="del_yn" javaType="String"></result><!--삭제여부(Y:예,N:아니오)-->
        <result property="regUid" column="reg_uid" javaType="String"></result><!--등록자ID-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
        <result property="modUid" column="mod_uid" javaType="String"></result><!--최종수정자ID-->
        <result property="modDate" column="mod_date" javaType="Date"></result><!--최종수정일시-->
    </resultMap>
    <insert id="insert" parameterType="Faq">
        /* 자주하는질문 등록 */
        INSERT INTO tb_faq (
               question,
               answer,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
             ) VALUES (
               #{entity.question},
               #{entity.answer},
               #{entity.delYn},
               #{entity.regUid},
               #{entity.regDate},
               #{entity.modUid},
               #{entity.modDate})
        <selectKey resultType="Integer" keyProperty="entity.faqIdx">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
    <update id="update" parameterType="Faq">
        /* 자주하는질문 수정 */
        UPDATE tb_faq 
               <set>
               <if test="entity.question != null">
               question = #{entity.question},
               </if>
               <if test="entity.answer != null">
               answer = #{entity.answer},
               </if>
               <if test="entity.delYn != null">
               del_yn = #{entity.delYn},
               </if>
               <if test="entity.regUid != null">
               reg_uid = #{entity.regUid},
               </if>
               <if test="entity.regDate != null">
               reg_date = #{entity.regDate},
               </if>
               <if test="entity.modUid != null">
               mod_uid = #{entity.modUid},
               </if>
               <if test="entity.modDate != null">
               mod_date = #{entity.modDate},
               </if>
               </set>
         WHERE faq_idx = #{entity.faqIdx}
    </update>
    <delete id="delete" parameterType="Faq">
        /* 자주하는질문 삭제 */
        DELETE FROM tb_faq 
         WHERE faq_idx = #{faqIdx}
    </delete>
    <select id="selectOne" resultMap="FaqRM">
        /* 자주하는질문 상세조회 */
        SELECT faq_idx,
               question,
               answer,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_faq
         WHERE faq_idx = #{faqIdx}
    </select>
    <select id="selectList" resultMap="FaqRM">
        /* 자주하는질문 목록조회 */
        SELECT faq_idx,
               question,
               answer,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_faq
               <if test="pageable != null">
         WHERE LIMIT #{pageable.start}, #{pageable.end}
               </if>
    </select>
    <select id="selectListCount" resultType="int">
        /* 자주하는질문 전체 개수 조회 */
        SELECT COUNT(*) AS CNT
          FROM tb_faq
         WHERE faq_idx = #{faqIdx}
    </select>
</mapper>