<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ewp.api.dao.DrResultDao">
    <resultMap type="DrResult" id="DrResultRM">
        <id property="drRstIdx" column="dr_rst_idx" javaType="Long"></id><!--DR실적식별자-->
        <result property="siteId" column="site_id" javaType="String"></result><!--사이트ID-->
        <result property="startTimestamp" column="start_timestamp" javaType="Date"></result><!--감축시작타임스탬프-->
        <result property="startDate" column="start_date" javaType="Date"></result><!--감축시작일시-->
        <result property="endTimestamp" column="end_timestamp" javaType="Date"></result><!--감축종료타임스탬프-->
        <result property="endDate" column="end_date" javaType="Date"></result><!--감축종료일시-->
        <result property="cblAmt" column="cbl_amt" javaType="Integer"></result><!--기준부하(CBL)(단위:mWh)-->
        <result property="actAmt" column="act_amt" javaType="Integer"></result><!--실제사용량(단위:mWh)-->
        <result property="contractPower" column="contract_power" javaType="Integer"></result><!--계약전력(단위:kW)-->
        <result property="goalPower" column="goal_power" javaType="Integer"></result><!--목표전력(단위:kW)-->
        <result property="rewardAmt" column="reward_amt" javaType="Integer"></result><!--감축정산금-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
        <result property="modDate" column="mod_date" javaType="Date"></result><!--최종수정일시-->
    </resultMap>
    <resultMap type="Cbl" id="CblRM">
        <id property="cblIdx" column="cbl_idx" javaType="Long"></id><!--Cbl식별자-->
        <result property="siteId" column="site_id" javaType="String"></result><!--사이트ID-->
        <result property="startTimestamp" column="start_timestamp" javaType="Date"></result><!--시작타임스탬프-->
        <result property="startDate" column="start_date" javaType="Date"></result><!--시작일시-->
        <result property="endTimestamp" column="end_timestamp" javaType="Date"></result><!--종료타임스탬프-->
        <result property="endDate" column="end_date" javaType="Date"></result><!--종료일시-->
        <result property="cbl" column="cbl" javaType="Integer"></result><!--기준부하-->
        <result property="cml" column="cml" javaType="Integer"></result><!--최소부하-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
    </resultMap>
    <insert id="insert" parameterType="DrResult">
        /* DR실적 등록 */
        INSERT INTO tb_dr_result (
               site_id,
               start_timestamp,
               start_date,
               end_timestamp,
               end_date,
               cbl_amt,
               act_amt,
               contract_power,
               goal_power,
               reward_amt,
               reg_date
             ) VALUES (
               #{entity.siteId},
               #{entity.startTimestamp},
               #{entity.startDate},
               #{entity.endTimestamp},
               #{entity.endDate},
               #{entity.cblAmt},
               #{entity.actAmt},
               #{entity.contractPower},
               #{entity.goalPower},
               #{entity.rewardAmt},
               NOW())
        <selectKey resultType="Long" keyProperty="entity.drRstIdx">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
    <update id="update" parameterType="DrResult">
        /* DR실적 수정 */
        UPDATE tb_dr_result 
               <set>
               <if test="entity.siteId != null">
               site_id = #{entity.siteId},
               </if>
               <if test="entity.startTimestamp != null">
               start_timestamp = #{entity.startTimestamp},
               </if>
               <if test="entity.startDate != null">
               start_date = #{entity.startDate},
               </if>
               <if test="entity.endTimestamp != null">
               end_timestamp = #{entity.endTimestamp},
               </if>
               <if test="entity.endDate != null">
               end_date = #{entity.endDate},
               </if>
               <if test="entity.cblAmt != null">
               cbl_amt = #{entity.cblAmt},
               </if>
               <if test="entity.actAmt != null">
               act_amt = #{entity.actAmt},
               </if>
               <if test="entity.contractPower != null">
               contract_power = #{entity.contractPower},
               </if>
               <if test="entity.goalPower != null">
               goal_power = #{entity.goalPower},
               </if>
               <if test="entity.rewardAmt != null">
               reward_amt = #{entity.rewardAmt},
               </if>
               <if test="entity.regDate != null">
               reg_date = #{entity.regDate},
               </if>
               <if test="entity.modDate != null">
               mod_date = #{entity.modDate},
               </if>
               </set>
         WHERE dr_rst_idx = #{entity.drRstIdx}
    </update>
    <delete id="delete" parameterType="DrResult">
        /* DR실적 삭제 */
        DELETE FROM tb_dr_result 
         WHERE dr_rst_idx = #{drRstIdx}
    </delete>
    <select id="selectOne" resultMap="DrResultRM">
        /* DR실적 상세조회 */
        SELECT dr_rst_idx,
               site_id,
               start_timestamp,
               start_date,
               end_timestamp,
               end_date,
               cbl_amt,
               act_amt,
               contract_power,
               goal_power,
               reward_amt,
               reg_date,
               mod_date
          FROM tb_dr_result
         WHERE dr_rst_idx = #{drRstIdx}
    </select>
    <select id="selectList" resultMap="DrResultRM">
        /* DR실적 목록조회 */
        SELECT dr_rst_idx,
               site_id,
               start_timestamp,
               start_date,
               end_timestamp,
               end_date,
               cbl_amt,
               act_amt,
               contract_power,
               goal_power,
               reward_amt,
               reg_date,
               mod_date
          FROM tb_dr_result
               <if test="pageable != null">
         WHERE LIMIT #{pageable.start}, #{pageable.end}
               </if>
    </select>
    <select id="selectListCount" resultType="int">
        /* DR실적 전체 개수 조회 */
        SELECT COUNT(*) AS CNT
          FROM tb_dr_result
         WHERE dr_rst_idx = #{drRstIdx}
    </select>
    
    <insert id="insertCbl" parameterType="Cbl">
        /* 기준부하 등록 */
        INSERT INTO tb_cbl (
               site_id,
               start_timestamp,
               start_date,
               end_timestamp,
               end_date,
               cbl,
               cml,
               reg_date
             ) VALUES (
               #{cbl.siteId},
               #{cbl.startTimestamp},
               #{cbl.startDate},
               #{cbl.endTimestamp},
               #{cbl.endDate},
               #{cbl.cbl},
               #{cbl.cml},
               NOW())
        <selectKey resultType="Long" keyProperty="cblIdx">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
    <update id="updateCbl" parameterType="Cbl">
        /* 기준부하 수정 */
        UPDATE tb_cbl 
               <set>
               <if test="cbl.siteId != null">
               site_id = #{cbl.siteId},
               </if>
               <if test="cbl.startTimestamp != null">
               start_timestamp = #{cbl.startTimestamp},
               </if>
               <if test="cbl.startDate != null">
               start_date = #{cbl.startDate},
               </if>
               <if test="cbl.endTimestamp != null">
               end_timestamp = #{cbl.endTimestamp},
               </if>
               <if test="cbl.endDate != null">
               end_date = #{cbl.endDate},
               </if>
               <if test="cbl.cbl != null">
               cbl = #{cbl.cbl},
               </if>
               <if test="cbl.cml != null">
               cml = #{cbl.cml},
               </if>
               mod_date = NOW(),
               </set>
         WHERE cbl_idx = #{cbl.cblIdx}
    </update>
    <select id="selectOneByUniqueCbl" resultMap="CblRM">
        /* 기준부하 상세조회ByUnique */
        SELECT cbl_idx,
               site_id,
               start_timestamp,
               start_date,
               end_timestamp,
               end_date,
               cbl,
               cml,
               reg_date,
               mod_date
          FROM tb_cbl
         WHERE site_id = #{siteId}
           AND start_timestamp = #{startTimestamp}
           AND end_timestamp = #{endTimestamp}
    </select>
</mapper>