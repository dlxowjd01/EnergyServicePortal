<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ewp.api.dao.DeviceDao">
    <resultMap type="Device" id="DeviceRM">
        <id property="deviceId" column="device_id" javaType="String"></id><!--장치ID-->
        <result property="siteId" column="site_id" javaType="String"></result><!--사이트ID-->
        <result property="userIdx" column="user_idx" javaType="Integer"></result><!--사용자식별자-->
        <result property="deviceName" column="device_name" javaType="String"></result><!--장치명-->
        <result property="deviceGrpIdx" column="device_grp_idx" javaType="Integer"></result><!--장치그룹식별자-->
        <result property="deviceType" column="device_type" javaType="String"></result><!--장치출처구분(1:부하측정기기,2:PV모니터링기기,3:ESS모니터링기기,4:PCS,5:BMS,6:PV)-->
        <result property="instType" column="inst_type" javaType="String"></result><!--설치구분(1:에너톡,2:로컬EMS)-->
        <result property="delYn" column="del_yn" javaType="String"></result><!--삭제여부(Y:예,N:아니오)-->
        <result property="regUid" column="reg_uid" javaType="String"></result><!--등록자ID-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
        <result property="modUid" column="mod_uid" javaType="String"></result><!--최종수정자ID-->
        <result property="modDate" column="mod_date" javaType="Date"></result><!--최종수정일시-->
    </resultMap>
    <insert id="insert" parameterType="Device">
        /* 장치 등록 */
        INSERT INTO tb_device (
               device_id,
               site_id,
               user_idx,
               device_name,
               device_grp_idx,
               device_type,
               inst_type,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
             ) VALUES (
               #{entity.deviceId},
               #{entity.siteId},
               #{entity.userIdx},
               #{entity.deviceName},
               #{entity.deviceGrpIdx},
               #{entity.deviceType},
               #{entity.instType},
               #{entity.delYn},
               #{entity.regUid},
               #{entity.regDate},
               #{entity.modUid},
               #{entity.modDate})
    </insert>
    <update id="update" parameterType="Device">
        /* 장치 수정 */
        UPDATE tb_device 
               <set>
               <if test="entity.siteId != null">
               site_id = #{entity.siteId},
               </if>
               <if test="entity.userIdx != null">
               user_idx = #{entity.userIdx},
               </if>
               <if test="entity.deviceName != null">
               device_name = #{entity.deviceName},
               </if>
               <if test="entity.deviceGrpIdx != null">
               device_grp_idx = #{entity.deviceGrpIdx},
               </if>
               <if test="entity.deviceType != null">
               device_type = #{entity.deviceType},
               </if>
               <if test="entity.instType != null">
               inst_type = #{entity.instType},
               </if>
               <if test="entity.delYn != null">
               del_yn = #{entity.delYn},
               </if>
               <if test="entity.regUid != null">
               reg_uid = #{entity.regUid},
               </if>
               <if test="entity.regDate != null">
               reg_date = #{entity.regDate},
               </if>
               <if test="entity.modUid != null">
               mod_uid = #{entity.modUid},
               </if>
               mod_date = NOW(),
               </set>
         WHERE device_id = #{entity.deviceId}
    </update>
    <delete id="delete" parameterType="Device">
        /* 장치 삭제 */
        DELETE FROM tb_device 
         WHERE device_id = #{deviceId}
    </delete>
    <select id="selectOne" resultMap="DeviceRM">
        /* 장치 상세조회 */
        SELECT device_id,
               site_id,
               user_idx,
               device_name,
               device_grp_idx,
               device_type,
               inst_type,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_device
         WHERE device_id = #{id}
    </select>
    <select id="selectList" resultMap="DeviceRM" fetchSize="100">
        /* 장치 목록조회 */
        SELECT device_id,
               site_id,
               user_idx,
               device_name,
               device_grp_idx,
               device_type,
               inst_type,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_device
         WHERE del_yn = 'N'
    </select>
    <select id="selectListBySiteId" resultMap="DeviceRM">
        /* SITE_ID 로 장치 목록조회 */
        SELECT device_id,
               site_id,
               user_idx,
               device_name,
               device_grp_idx,
               device_type,
               inst_type,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_device
         WHERE site_id = #{siteId}
           AND del_yn = 'N'
    </select>
    <select id="selectListCount" resultType="int">
        /* 장치 전체 개수 조회 */
        SELECT COUNT(*) AS CNT
          FROM tb_device
         WHERE device_id = #{deviceId}
    </select>
</mapper>