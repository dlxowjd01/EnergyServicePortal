<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ewp.api.dao.SiteDao">
    <resultMap type="Site" id="SiteRM">
        <id property="siteId" column="site_id" javaType="String"></id><!--사이트ID-->
        <result property="userIdx" column="user_idx" javaType="Integer"></result><!--사용자식별자-->
        <result property="siteName" column="site_name" javaType="String"></result><!--사이트명-->
        <result property="siteGrpIdx" column="site_grp_idx" javaType="Integer"></result><!--사이트그룹식별자-->
        <result property="areaType" column="area_type"
                javaType="String"></result><!--지역구분(01:서울,02:부산,03:대구,04:인천,05:광주,06:대전,07:울산,08:세종,09:경기,10:강원,11:충북,12:충남,13:전북,14:전남,15:경북,16:경남,17:제주)-->
        <result property="timeZone" column="time_zone" javaType="String"></result><!--타임Zone(예:GMT+8)-->
        <result property="localEmsAddr" column="local_ems_addr" javaType="String"></result><!--Local EMS 주소-->
        <result property="localEmsKey" column="local_ems_key" javaType="String"></result><!--Local EMS 암호키-->
        <result property="delYn" column="del_yn" javaType="String"></result><!--삭제여부(Y:예,N:아니오)-->
        <result property="regUid" column="reg_uid" javaType="String"></result><!--등록자ID-->
        <result property="regDate" column="reg_date" javaType="Date"></result><!--등록일시-->
        <result property="modUid" column="mod_uid" javaType="String"></result><!--최종수정자ID-->
        <result property="modDate" column="mod_date" javaType="Date"></result><!--최종수정일시-->
    </resultMap>
    <insert id="insert" parameterType="Site">
        /* 사이트 등록 */
        INSERT INTO tb_site (
               site_id,
               user_idx,
               site_name,
               site_grp_idx,
               area_type,
               time_zone,
               local_ems_addr,
               local_ems_key,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
             ) VALUES (
               #{entity.siteId},
               #{entity.userIdx},
               #{entity.siteName},
               #{entity.siteGrpIdx},
               #{entity.areaType},
               #{entity.timeZone},
               #{entity.localEmsAddr},
               #{entity.localEmsKey},
               #{entity.delYn},
               #{entity.regUid},
               #{entity.regDate},
               #{entity.modUid},
               #{entity.modDate})
    </insert>
    <update id="update" parameterType="Site">
        /* 사이트 수정 */
        UPDATE tb_site
        <set>
            <if test="entity.userIdx != null">
                user_idx = #{entity.userIdx},
            </if>
            <if test="entity.siteName != null">
                site_name = #{entity.siteName},
            </if>
            <if test="entity.siteGrpIdx != null">
                site_grp_idx = #{entity.siteGrpIdx},
            </if>
            <if test="entity.areaType != null">
                area_type = #{entity.areaType},
            </if>
            <if test="entity.timeZone != null">
                time_zone = #{entity.timeZone},
            </if>
            <if test="entity.localEmsAddr != null">
                local_ems_addr = #{entity.localEmsAddr},
            </if>
            <if test="entity.localEmsKey != null">
                local_ems_key = #{entity.localEmsKey},
            </if>
            <if test="entity.delYn != null">
                del_yn = #{entity.delYn},
            </if>
            <if test="entity.regUid != null">
                reg_uid = #{entity.regUid},
            </if>
            <if test="entity.regDate != null">
                reg_date = #{entity.regDate},
            </if>
            <if test="entity.modUid != null">
                mod_uid = #{entity.modUid},
            </if>
            mod_date = NOW(),
        </set>
        WHERE site_id = #{entity.siteId}
    </update>
    <delete id="delete" parameterType="Site">
        /* 사이트 삭제 */
        DELETE FROM tb_site 
         WHERE site_id = #{siteId}
    </delete>
    <select id="selectOne" resultMap="SiteRM">
        /* 사이트 상세조회 */
        SELECT site_id,
               user_idx,
               site_name,
               site_grp_idx,
               area_type,
               time_zone,
               local_ems_addr,
               local_ems_key,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_site
         WHERE site_id = #{id}
           AND del_yn = 'N'
    </select>
    <select id="selectList" resultMap="SiteRM" fetchSize="100">
        /* 사이트 목록조회 */
        SELECT site_id,
               user_idx,
               site_name,
               site_grp_idx,
               area_type,
               time_zone,
               local_ems_addr,
               local_ems_key,
               del_yn,
               reg_uid,
               reg_date,
               mod_uid,
               mod_date
          FROM tb_site
         WHERE del_yn = 'N'
    </select>
    <select id="selectListCount" resultType="int">
        /* 사이트 전체 개수 조회 */
        SELECT COUNT(*) AS CNT
          FROM tb_site
         WHERE site_id = #{siteId}
    </select>
</mapper>